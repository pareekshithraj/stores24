generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id             Int        @id @default(autoincrement())
  name           String
  barcode        String     @unique
  price          Float
  gst_percentage Float
  stock          Int        @default(0)
  saleItems      SaleItem[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Sales {
  id             Int        @id @default(autoincrement())
  bill_number    String     @unique
  total_amount   Float
  payment_method String     // e.g. "Cash", "UPI", "Card"
  customer_id    Int?       // Optional link to Customer
  customer       Customer?  @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  date           DateTime   @default(now())
  saleItems      SaleItem[]
}

model SaleItem {
  id         Int      @id @default(autoincrement())
  sale_id    Int
  product_id Int
  quantity   Int
  price      Float    // Price recorded at the exact time of sale
  sale       Sales    @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Restrict)
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  username  String   @unique
  role      String   // e.g. "Administrator", "Cashier", "Inventory Manager"
  password  String
  status    String   @default("Active") // "Active", "Inactive"
  lastLogin DateTime?
  createdAt DateTime @default(now())
}

model Supplier {
  id        Int      @id @default(autoincrement())
  name      String
  contact   String
  phone     String
  email     String
  category  String
  active    Boolean  @default(true)
  purchases PurchaseOrder[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PurchaseOrder {
  id           Int      @id @default(autoincrement())
  po_number    String   @unique
  supplier_id  Int
  supplier     Supplier @relation(fields: [supplier_id], references: [id], onDelete: Restrict)
  items_count  Int      @default(0)
  total_amount Float    @default(0)
  status       String   @default("Pending") // "Pending", "Received"
  date         DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id           Int      @id @default(autoincrement())
  phone        String   @unique
  name         String?
  total_points Int      @default(0)
  purchases    Sales[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContactInquiry {
  id           Int      @id @default(autoincrement())
  firstName    String
  lastName     String
  email        String
  organization String
  interest     String
  message      String?
  source       String   @default("website")
  createdAt    DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}
